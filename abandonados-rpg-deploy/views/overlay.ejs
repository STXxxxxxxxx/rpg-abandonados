<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Overlay | <%= character.nome %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
    <script src="/socket.io/socket.io.js"></script>
    <style>
      :root {
        --black: #000000;
        --black-soft: #050505;
        --iron: #1a1a1a;
        --iron-light: #2a2a2a;
        --silver: #e5ded2;
        --silver-muted: #8f887d;
        --blood: #7f0615;
        --blood-text: #d8c7c7;
        --mind: #4c1768;
        --mind-text: #d9d0e4;
      }

      * {
        box-sizing: border-box;
      }

      body {
        width: 100vw;
        height: 100vh;
        margin: 0;
        overflow: hidden;
        background: transparent;
        font-family: "Cinzel", Georgia, serif;
      }

      .overlay-shell {
        position: fixed;
        left: 40px;
        bottom: 54px;
        width: max-content;
        max-width: none;
        padding: 0 60px;
        color: var(--silver);
        overflow: visible;
      }

      .hud {
        position: relative;
        width: 1180px;
        min-height: 156px;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 34px;
        flex-wrap: nowrap;
        padding: 26px 60px;
        background: var(--black);
        border: 2px solid var(--iron-light);
        clip-path: polygon(
          34px 0,
          calc(100% - 34px) 0,
          100% 50%,
          calc(100% - 34px) 100%,
          34px 100%,
          0 50%
        );
        box-shadow:
          0 18px 34px rgba(0, 0, 0, 0.92),
          0 0 0 4px #050505,
          inset 0 0 0 1px rgba(255, 255, 255, 0.05),
          inset 0 0 28px rgba(255, 255, 255, 0.025),
          inset 0 -18px 28px rgba(0, 0, 0, 0.98);
      }

      .hud::before,
      .hud::after {
        content: "";
        position: absolute;
        top: 50%;
        width: 58px;
        height: 104px;
        background: var(--black);
        border: 2px solid var(--iron-light);
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.045),
          inset 0 0 18px rgba(0, 0, 0, 0.96),
          0 10px 20px rgba(0, 0, 0, 0.76);
      }

      .hud::before {
        left: -31px;
        transform: translateY(-50%);
        clip-path: polygon(0 50%, 42% 0, 100% 20%, 78% 50%, 100% 80%, 42% 100%);
      }

      .hud::after {
        right: -31px;
        transform: translateY(-50%) scaleX(-1);
        clip-path: polygon(0 50%, 42% 0, 100% 20%, 78% 50%, 100% 80%, 42% 100%);
      }

      .name-plate {
        position: relative;
        flex: 0 0 400px;
        width: 400px;
        min-width: 400px;
        height: 88px;
        display: flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        padding: 0 34px;
        background: var(--black-soft);
        border: 1px solid var(--iron-light);
        clip-path: polygon(22px 0, calc(100% - 22px) 0, 100% 50%, calc(100% - 22px) 100%, 22px 100%, 0 50%);
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.035),
          inset 0 0 22px rgba(0, 0, 0, 0.95),
          0 10px 20px rgba(0, 0, 0, 0.62);
      }

      .name-plate::before,
      .name-plate::after {
        content: "";
        position: absolute;
        top: 50%;
        width: 9px;
        height: 52px;
        background: #111111;
        border: 1px solid #303030;
        transform: translateY(-50%);
      }

      .name-plate::before {
        left: 17px;
      }

      .name-plate::after {
        right: 17px;
      }

      .overlay-title {
        position: relative;
        z-index: 1;
        max-width: 100%;
        margin: 0;
        color: var(--silver);
        font-size: clamp(1.7rem, 2.35vw, 2.35rem);
        font-weight: 900;
        line-height: 1;
        letter-spacing: 0.18em;
        text-align: center;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-shadow: 0 2px 0 #000, 0 0 16px rgba(229, 222, 210, 0.12);
      }

      .stats {
        flex: 0 0 626px;
        width: 626px;
        min-width: 626px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        white-space: nowrap;
      }

      .stat {
        flex: 0 0 301px;
        width: 301px;
        min-width: 301px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        white-space: nowrap;
      }

      .medallion {
        width: 74px;
        height: 74px;
        display: grid;
        place-items: center;
        border-radius: 999px;
        background: #000;
        border: 2px solid #262626;
        box-shadow:
          0 8px 16px rgba(0, 0, 0, 0.72),
          inset 0 0 0 3px #070707,
          inset 0 0 0 5px #222,
          inset 0 0 18px rgba(0, 0, 0, 0.98);
      }

      .medallion svg {
        width: 34px;
        height: 34px;
        display: block;
        filter: drop-shadow(0 0 7px currentColor);
      }

      .stat-life .medallion {
        color: var(--blood);
      }

      .stat-mind .medallion {
        color: var(--mind);
      }

      .stat-body {
        display: grid;
        gap: 7px;
        flex: 0 0 207px;
        width: 207px;
        min-width: 207px;
        white-space: nowrap;
      }

      .stat-label {
        color: var(--silver-muted);
        font-size: 0.88rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        text-align: center;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .value-box {
        width: 207px;
        min-width: 207px;
        min-height: 52px;
        display: grid;
        place-items: center;
        padding: 0 18px;
        white-space: nowrap;
        background: #000;
        border: 1px solid #292929;
        clip-path: polygon(14px 0, calc(100% - 14px) 0, 100% 50%, calc(100% - 14px) 100%, 14px 100%, 0 50%);
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.035),
          inset 0 0 18px rgba(0, 0, 0, 0.98),
          0 8px 16px rgba(0, 0, 0, 0.62);
      }

      .stat-number {
        font-size: 2.36rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: 0.04em;
        text-align: center;
        white-space: nowrap;
      }

      .stat-life .stat-number {
        color: var(--blood-text);
        text-shadow: 0 0 10px rgba(127, 6, 21, 0.24);
      }

      .stat-mind .stat-number {
        color: var(--mind-text);
        text-shadow: 0 0 10px rgba(76, 23, 104, 0.24);
      }

      .overlay-shell.hud-shake .hud {
        animation: hudShake 420ms cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
      }

      @keyframes hudShake {
        0%,
        100% {
          transform: translate(0, 0);
        }

        20% {
          transform: translate(-4px, 2px);
        }

        40% {
          transform: translate(5px, -2px);
        }

        60% {
          transform: translate(-3px, -2px);
        }

        80% {
          transform: translate(3px, 1px);
        }
      }

      @media (max-width: 1320px) {
        .overlay-shell {
          left: 24px;
          bottom: 24px;
          transform: scale(0.82);
          transform-origin: left bottom;
        }
      }
    </style>
  </head>
  <body>
    <aside class="overlay-shell" aria-live="polite">
      <main class="hud">
        <section class="name-plate" aria-label="Nome do personagem">
          <h1 class="overlay-title" id="overlayName"><%= character.nome %></h1>
        </section>

        <section class="stats" aria-label="Status vitais">
          <article class="stat stat-life" aria-label="Vida">
            <div class="medallion" aria-hidden="true">
              <svg viewBox="0 0 64 64" role="img" aria-label="Coracao">
                <path
                  fill="currentColor"
                  d="M32 55S7 39.7 7 22.6C7 14.9 12.5 9 19.5 9c4.7 0 9.1 2.6 11.5 6.7L32 17.3l1-1.6C35.4 11.6 39.8 9 44.5 9 51.5 9 57 14.9 57 22.6 57 39.7 32 55 32 55Z"
                />
              </svg>
            </div>

            <div class="stat-body">
              <div class="stat-label">&#10022; Vida &#10022;</div>
              <div class="value-box">
                <strong class="stat-number" id="overlayPv">0 / 0</strong>
              </div>
            </div>
          </article>

          <article class="stat stat-mind" aria-label="Sanidade">
            <div class="medallion" aria-hidden="true">
              <svg viewBox="0 0 64 64" role="img" aria-label="Cerebro">
                <path
                  fill="currentColor"
                  d="M22.3 8.8c-5.3 0-9.7 3.9-10.4 9C8.2 19.6 6 23.4 6 27.8c0 3.4 1.4 6.4 3.8 8.5-.3.9-.4 1.8-.4 2.7 0 5.3 4.3 9.6 9.6 9.6h2.3c1.3 4 5.1 6.9 9.6 6.9 5.5 0 10-4.5 10-10V17c0-4.6-3.7-8.2-8.2-8.2-2.6 0-4.9 1.2-6.4 3.1-1-1.9-2.5-3.1-4-3.1Zm18.7 1.5v45.2h3c4.7 0 8.7-3.4 9.5-7.9 3.2-1.7 5.4-5 5.4-8.9 0-2.2-.7-4.2-1.9-5.9 1-1.6 1.6-3.5 1.6-5.5 0-5.3-3.9-9.7-9-10.4-.9-4.5-4.5-7.6-8.6-6.6Z"
                />
              </svg>
            </div>

            <div class="stat-body">
              <div class="stat-label">&#10022; Sanidade &#10022;</div>
              <div class="value-box">
                <strong class="stat-number" id="overlayPs">0 / 0</strong>
              </div>
            </div>
          </article>
        </section>
      </main>
    </aside>

    <script>
      window.__CHARACTER__ = <%- characterJson %>;
      window.__OVERLAY_TOKEN__ = "<%= overlayToken %>";
    </script>
    <script src="/public/js/overlay.js"></script>
  </body>
</html>
